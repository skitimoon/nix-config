#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage: scripts/update-kdeconnect [build-number] [--file PATH] [--print-only]

Update config/kdeconnect.nix with the latest macOS arm64 KDE Connect CI build,
or with an explicit build number if provided.

Examples:
  scripts/update-kdeconnect
  scripts/update-kdeconnect 5958
  scripts/update-kdeconnect --print-only
EOF
}

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
target_file="$repo_root/config/kdeconnect.nix"
print_only=0
requested_version=""

while (($# > 0)); do
  case "$1" in
    -h|--help)
      usage
      exit 0
      ;;
    --file)
      shift
      target_file="${1:?missing path after --file}"
      ;;
    --print-only)
      print_only=1
      ;;
    -*)
      echo "Unknown option: $1" >&2
      usage >&2
      exit 1
      ;;
    *)
      if [[ -n "$requested_version" ]]; then
        echo "Only one build number may be provided" >&2
        exit 1
      fi
      requested_version="$1"
      ;;
  esac
  shift
done

base_url="https://cdn.kde.org/ci-builds/network/kdeconnect-kde/master/macos-arm64"

if [[ -n "$requested_version" ]]; then
  version="$requested_version"
else
  version="$(
    curl -fsSL "$base_url/" \
      | grep -Eo 'kdeconnect-kde-master-[0-9]+-macos-clang-arm64\.dmg' \
      | sed -E 's/.*-([0-9]+)-macos-clang-arm64\.dmg/\1/' \
      | sort -n \
      | tail -n1
  )"
fi

if [[ -z "$version" ]]; then
  echo "Could not determine KDE Connect build number" >&2
  exit 1
fi

url="$base_url/kdeconnect-kde-master-${version}-macos-clang-arm64.dmg"
hash="$(
  nix store prefetch-file --json "$url" \
    | sed -nE 's/.*"hash"[[:space:]]*:[[:space:]]*"([^"]+)".*/\1/p'
)"

if [[ -z "$hash" ]]; then
  echo "Could not extract hash for $url" >&2
  exit 1
fi

echo "Version: $version"
echo "URL: $url"
echo "Hash: $hash"

if ((print_only)); then
  exit 0
fi

if [[ ! -f "$target_file" ]]; then
  echo "Target file not found: $target_file" >&2
  exit 1
fi

TARGET_FILE="$target_file" VERSION="$version" HASH="$hash" perl -0pi -e '
  my $version = $ENV{VERSION};
  my $hash = $ENV{HASH};

  s/version = "[^"]+";/version = "$version";/
    or die "Failed to update version\n";
  s/((?:sha256|hash)\s*=\s*)"[^"]+";/${1}"$hash";/
    or die "Failed to update hash\n";
' "$target_file"

echo "Updated $target_file"
